    "ingredients": [
      { "name": "spaghetti",          "quantity": 400, "unit": "g",   "rawText": "400g spaghetti" },
      { "name": "pancetta",            "quantity": 150, "unit": "g",   "rawText": "150g pancetta or guanciale" },
      { "name": "egg",                 "quantity": 4,               "rawText": "4 large eggs" },
      { "name": "parmesan cheese",     "quantity": 80,  "unit": "g",   "rawText": "80g grated Parmesan" },
      { "name": "black pepper",        "quantity": 1,   "unit": "tsp", "rawText": "1 tsp freshly ground black pepper" },
      { "name": "salt",                "quantity": 1,   "unit": "tsp", "rawText": "Salt to taste" }
    ],
    "instructions": [
      { "step": 1, "text": "Cook spaghetti in well-salted boiling water until al dente. Reserve 1 cup of pasta water." },
      { "step": 2, "text": "Fry pancetta in a large skillet over medium heat until crispy. Remove from heat." },
      { "step": 3, "text": "Whisk eggs with grated Parmesan and plenty of black pepper in a bowl." },
      { "step": 4, "text": "Drain pasta and immediately toss into the skillet with pancetta off the heat." },
      { "step": 5, "text": "Pour the egg mixture over pasta and toss quickly, adding pasta water a splash at a time until silky and creamy." },
      { "step": 6, "text": "Serve immediately with extra Parmesan and black pepper." }
